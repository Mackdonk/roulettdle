# Copy to .env.local for development. For production (e.g. Vercel), add the same
# keys in the host’s environment settings — never commit real secrets.

# Public URL (browser + server OK)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Service role — server only (Route Handlers / server code). Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
